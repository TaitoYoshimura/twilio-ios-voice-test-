# Copy this file to .env in the same directory and fill in local PoC values.
# Do not commit .env.

# If TOKEN_ENDPOINT is set, the app fetches a Voice access token from this URL.
# If it is empty, the app can generate a local Twilio Voice access token from
# ACCOUNT_SID, API_KEY_SID, API_KEY_SECRET, and TWIML_APP_SID below.
TOKEN_ENDPOINT=https://example.twil.io/token
DEFAULT_IDENTITY=ios_poc_user
DEFAULT_TO_NUMBER=+819012345678
CALLER_ID=+819012345678

# Local PoC credentials for app-side token generation.
ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
API_KEY_SECRET=replace_me
TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
